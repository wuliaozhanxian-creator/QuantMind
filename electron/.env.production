# QuantMind 前端生产构建环境
# 可从 .env.template 复制并按需修改
#
# 默认（本地预览直连）：
VITE_SERVICE_HOST=127.0.0.1
VITE_HTTP_PROTOCOL=http
VITE_API_BASE_URL=http://127.0.0.1:8000
# VITE_USER_API_URL=http://127.0.0.1:8000/api/v1
VITE_WS_BASE_URL=ws://127.0.0.1:8003/api/v1/ws/market
#
# 同域反向代理方案（可选）：
# VITE_API_BASE_URL=http://127.0.0.1
# VITE_WS_BASE_URL=ws://127.0.0.1/ws/api/v1/ws/market

# 远程 HTTPS 直连方案（可选）：
# VITE_SERVICE_HOST=YOUR_SERVER_HOST
# VITE_HTTP_PROTOCOL=https
# VITE_API_BASE_URL=https://YOUR_SERVER_HOST
# VITE_USER_API_URL=https://YOUR_SERVER_HOST/api/v1
# VITE_WS_BASE_URL=wss://YOUR_SERVER_HOST/ws/api/v1/ws/market
