# QuantMind Electron 环境变量模板
# 用法：
# 1) 开发模式：复制为 .env.local
#    cp electron/.env.template electron/.env.local
# 2) 生产构建：复制为 .env.production
#    cp electron/.env.template electron/.env.production

# ========= 基础 =========
# 仅用于启动日志展示，可选
VITE_SERVICE_HOST=127.0.0.1
# http 或 https
VITE_HTTP_PROTOCOL=http

# ========= API / WS =========
# 默认方案（可直接运行）：本地直连后端端口
VITE_API_BASE_URL=http://127.0.0.1:8000
# 认证服务地址（可选）：默认不设置，自动复用 VITE_API_BASE_URL 并拼接 /api/v1
# VITE_USER_API_URL=http://127.0.0.1:8000/api/v1
VITE_WS_BASE_URL=ws://127.0.0.1:8003/api/v1/ws/market

# 方案 A（同域反向代理，常用于线上）
# VITE_API_BASE_URL=http://127.0.0.1
# VITE_WS_BASE_URL=ws://127.0.0.1/ws/api/v1/ws/market

# 方案 B（远程服务器直连）
# VITE_SERVICE_HOST=YOUR_SERVER_HOST
# VITE_API_BASE_URL=http://YOUR_SERVER_HOST
# VITE_USER_API_URL=http://YOUR_SERVER_HOST/api/v1
# VITE_WS_BASE_URL=ws://YOUR_SERVER_HOST/ws/api/v1/ws/market

# HTTPS 远程直连示例
# VITE_HTTP_PROTOCOL=https
# VITE_API_BASE_URL=https://YOUR_SERVER_HOST
# VITE_USER_API_URL=https://YOUR_SERVER_HOST/api/v1
# VITE_WS_BASE_URL=wss://YOUR_SERVER_HOST/ws/api/v1/ws/market

# ========= 多租户（可选） =========
# VITE_TENANT_ID=default
