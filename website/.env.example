# 支付宝配置
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_application_private_key
ALIPAY_PUBLIC_KEY=alipay_public_key
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=https://www.quantmindai.cn/api/v1/subscription/alipay-notify
ALIPAY_RETURN_URL=https://www.quantmindai.cn/api/v1/subscription/alipay-return

# JWT 配置（与 quantmind-api 共享）
JWT_SECRET_KEY=your_jwt_secret_key

# 前端 URL
FRONTEND_URL=http://localhost:8888

# 后端 API 地址
QUANTMIND_API_BASE_URL=https://api.quantmind.cloud

# 服务器端口
PORT=3000
