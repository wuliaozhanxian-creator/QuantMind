# QuantMind OSS Edition - 环境变量配置示例
# 复制此文件为 .env 并填入真实值：cp .env.example .env
# 切勿将含真实凭证的 .env 提交到版本控制（.gitignore 已忽略 .env）
#
# 安全说明（T6.1/T6.2/T6.3）：
#   - 所有密钥/密码已移除硬编码默认值，强制通过 .env 注入
#   - 未配置必需密钥时服务 fail-fast 拒绝启动
#   - 远程数据源为只读，禁止写入

# ============================================================
# 本地数据库 (PostgreSQL) - 必填
# docker-compose.yml 中 db 服务使用这些变量初始化数据库
# quantmind 服务通过 DB_HOST=db 连接容器内数据库
# ============================================================
DB_HOST=db
DB_PORT=5432
DB_NAME=quantmind
DB_USER=quantmind
# 数据库密码（必填，T6.1 移除硬编码默认值，强制注入）
DB_PASSWORD=

# ============================================================
# Redis 缓存 - 必填
# docker-compose.yml 中 redis 服务默认无密码
# quantmind 服务通过 REDIS_HOST=redis 连接容器内 Redis
# Redis DB 分配：0=general, 1=auth, 2=trade, 3=market, 4=backtest, 5=cache
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================
# 应用安全密钥 - 必填
# T6.1 移除硬编码默认密钥，强制通过 .env 注入
# 生成示例：python -c "import secrets; print(secrets.token_urlsafe(32))"
# SECRET_KEY: 会话/加密通用密钥
# JWT_SECRET_KEY: JWT 签名密钥
# ============================================================
SECRET_KEY=
JWT_SECRET_KEY=

# ============================================================
# 服务间调用与安全入口 - 必填
# T6.5-P3: INTERNAL_CALL_SECRET 已废弃（DEPRECATED），服务间认证统一使用
#          service JWT（由 SECRET_KEY 签发，X-Service-Token header 传递）。
#          此变量仅保留用于训练容器回调 (X-Internal-Call-Secret)，
#          待 docker/training/train.py 迁移后将彻底移除。
# ADMIN_SECURE_ENTRY_KEY: 管理员安全登录入口密钥（T6.3 未配置则 fail-fast）
# ============================================================
INTERNAL_CALL_SECRET=
ADMIN_SECURE_ENTRY_KEY=

# ============================================================
# 存储模式 - OSS 单机部署固定为 local
# ============================================================
STORAGE_MODE=local

# ============================================================
# 远程数据源 PostgreSQL（只读）- 已废弃
# ------------------------------------------------------------
# M2 安全加固后，market_db_manager.py 已改为读取容器内本地 PostgreSQL
#（DB_* 环境变量），远程行情 PostgreSQL（106.53.100.144）已废弃。
# 此处保留配置仅作历史参考，不再使用。
# 如未来恢复远程 PG 连接，必须使用只读用户白名单中的账号：
#   quantmind_market / readonly_monitor / quantmind_readonly
# 硬约束：仅读取，禁止写入远程库（T5.1 只读凭据隔离）
# ============================================================
# SOURCE_DB_HOST=
# SOURCE_DB_PORT=5432
# SOURCE_DB_NAME=quantmind
# SOURCE_DB_USER=
# SOURCE_DB_PASSWORD=

# ============================================================
# 远程行情 Redis（只读）- 可选
# 用于实盘行情推送，覆盖 remote_redis_client.py 中 Fernet 加密硬编码默认值
# 硬约束：仅读取，禁止写入（T5.1 只读凭据隔离）
# ------------------------------------------------------------
# T5.1 只读凭据隔离：配置 REMOTE_QUOTE_REDIS_USER 时，必须在只读用户
# 白名单中：readonly_monitor / quantmind_readonly
# 未配置用户名时（本地 Redis 无 ACL），允许通过。
# 使用读写凭据连接远程行情 Redis 将触发 RuntimeError fail-fast。
# ============================================================
# REMOTE_QUOTE_REDIS_HOST=
# REMOTE_QUOTE_REDIS_PORT=6379
# REMOTE_QUOTE_REDIS_USER=
# REMOTE_QUOTE_REDIS_PASSWORD=
